# ============================================================
# Musfi Store — Environment Variables for Coolify Deployment
# ============================================================
# Copy this file to .env and fill in your actual values.
# In Coolify, set these in the Environment Variables section.

# ----- Node -----
NODE_ENV=production

# ----- Ports -----
BACKEND_PORT=9000
STOREFRONT_PORT=8000

# ----- Database (PostgreSQL) -----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://medusa:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/musfi_store

# ----- Cache (Redis) -----
# Format: redis://HOST:PORT  or  redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://YOUR_REDIS_HOST:6379

# ----- Security Secrets (change these!) -----
JWT_SECRET=change-this-to-a-long-random-string
COOKIE_SECRET=change-this-to-a-long-random-string

# ----- CORS (update with your actual domains) -----
STORE_CORS=http://localhost:8000,https://musfi-store.yourdomain.com
ADMIN_CORS=http://localhost:9000,https://api.musfi-store.yourdomain.com
AUTH_CORS=http://localhost:9000,http://localhost:8000,https://api.musfi-store.yourdomain.com,https://musfi-store.yourdomain.com

# ----- Storefront -----
# Get this from Admin Dashboard → Settings → Publishable API Keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL of your backend (as seen from the browser, not from Docker internal)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.musfi-store.yourdomain.com

# Default region (us, eu, dk, etc.)
NEXT_PUBLIC_DEFAULT_REGION=us

# Base URL of your storefront
NEXT_PUBLIC_BASE_URL=https://musfi-store.yourdomain.com
